# .env.local.example

# =============================
# Admin API (local dev)
# =============================
# DEV: browser calls should be same-origin and proxied.
VITE_ADMIN_API_BASE=/admin-api

# Some parts of the UI still read VITE_API_URL.
# DEV: keep this EMPTY so requests stay relative and hit the Vite proxy -> http://localhost:5000
VITE_API_URL=

# DEV: where Vite should proxy /admin-api/* and /api/*.
# Use dev-only vars so localhost never drifts to production.
# Preferred:
# - Local backend:  VITE_DEV_PROXY_TARGET=http://localhost:5000
# - Or (start scripts): VITE_ADMIN_API_TARGET=http://localhost:5000
VITE_DEV_PROXY_TARGET=http://localhost:5000

# Avoid using VITE_PROXY_TARGET in development (often points to production for build/preview).
# VITE_PROXY_TARGET=

# PROD (Vercel): proxy-only contract.
# Leave this as '/admin-api' and configure Vercel rewrites for /admin-api/*.

# PROD (optional/legacy): only if you intentionally run in direct mode
# VITE_API_URL=https://PROD_BACKEND_DOMAIN

# ✅ Founder Control Access (Frontend OK – not secret)
VITE_FOUNDER_PIN=NewsPulse#80121972

# 🚀 Founder Control mocks (enable during local dev unless backend is ready)
VITE_USE_MOCK=true

# 🔐 Backend-only (documented here; do not commit real values)
FOUNDER_ID=FOUND-001
FOUNDER_EMAIL=founder@example.com
FOUNDER_PIN_SALT=somesalt
EMERGENCY_CODE=NewsPulse#80121972
REACTIVATION_PHRASE=Kiran#80121972
BACKUP_BUCKET=newspulse-backups-dev
